{
  "name": "rocketmq.js",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix packages/",
    "lint:check": "eslint packages/",
    "fmt": "prettier --write 'packages/**/src/**/*.ts' 'examples/**/*.ts'",
    "fmt:check": "prettier --check 'packages/**/src/**/*.ts' 'examples/**/*.ts'",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "pub:example": "tsx examples/publisher.ts",
    "sub:example": "tsx examples/consumer.ts"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.0"
  }
}
