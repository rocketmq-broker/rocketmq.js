{
  "name": "rocketmq.js",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix packages/",
    "lint:check": "eslint packages/",
    "fmt": "prettier --write 'packages/**/src/**/*.ts' 'examples/**/*.ts'",
    "fmt:check": "prettier --check 'packages/**/src/**/*.ts' 'examples/**/*.ts'",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "dec": "tsc -p tsconfig.examples.json && node --enable-source-maps examples/dist/publisher-dec.js",
    "zod": "tsc -p tsconfig.examples.json && node --enable-source-maps examples/dist/publisher-zod.js"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.40",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
